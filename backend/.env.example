PORT=5000
# MongoDB Atlas example: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/taskflow?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/taskflow
# Local dev:
CLIENT_ORIGIN=http://localhost:5173
# Production (set this in Render dashboard env vars):
# CLIENT_ORIGIN=https://task-tracker-two-tawny.vercel.app
NODE_ENV=development
